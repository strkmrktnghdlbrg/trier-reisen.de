---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { city } from "../data/city";
import { analytics, gtmEnabled } from "../data/analytics";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  /** Ein oder mehrere JSON-LD-Schema-Objekte. */
  schema?: object | object[];
}

const {
  title,
  description = city.description.short,
  noindex = false,
  canonical,
  ogImage,
  schema,
} = Astro.props;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, city.domain).toString();
const fullTitle = title === city.name ? `${city.name} · ${city.brandName}` : `${title} · ${city.brandName}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    {/*
      Drittanbieter-Scripts (Stay22, GetYourGuide, AdSense, GTM) werden
      ausschliesslich nach Einwilligung vom CookieBanner geladen.
    */}

    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    {gtmEnabled && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${analytics.gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
