---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { city } from "../data/city";
import { affiliate, stay22Enabled, gygEnabled } from "../data/affiliate";
import { adsense, adsenseEnabled } from "../data/adsense";
import { analytics, gtmEnabled } from "../data/analytics";
import type { Lang } from "../lib/i18n";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  /** Ein oder mehrere JSON-LD-Schema-Objekte. */
  schema?: object | object[];
  /** Sprache der aktuellen Seite (de = default, en = /en/...). */
  lang?: Lang;
  /** Pfad der jeweils anderen Sprachversion fuer hreflang. */
  altLangPath?: string;
}

const {
  title,
  description = city.description.short,
  noindex = false,
  canonical,
  ogImage,
  schema,
  lang = "de",
  altLangPath,
} = Astro.props;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, city.domain).toString();
const fullTitle = title === city.name ? `${city.name} · ${city.brandName}` : `${title} · ${city.brandName}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* hreflang: aktuelle + alternative Sprache + x-default (de) */}
    <link rel="alternate" hreflang={lang === "de" ? "de" : "en"} href={canonicalUrl} />
    {altLangPath && (
      <link
        rel="alternate"
        hreflang={lang === "de" ? "en" : "de"}
        href={new URL(altLangPath, city.domain).toString()}
      />
    )}
    <link
      rel="alternate"
      hreflang="x-default"
      href={lang === "de" ? canonicalUrl : (altLangPath ? new URL(altLangPath, city.domain).toString() : canonicalUrl)}
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    {altLangPath && <meta property="og:locale:alternate" content={lang === "de" ? "en_US" : "de_DE"} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    {stay22Enabled && (
      <script
        is:inline
        async
        src={`https://snippet.stay22.com/allez/script?lmaid=${affiliate.stay22.lmaId}`}
      ></script>
    )}
    {gygEnabled && (
      <script
        is:inline
        async
        defer
        src="https://widget.getyourguide.com/dist/pa.umd.production.min.js"
        data-gyg-partner-id={affiliate.getYourGuide.partnerId}
      ></script>
    )}
    {adsenseEnabled && !noindex && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.publisherId}`}
        crossorigin="anonymous"
      ></script>
    )}
    {gtmEnabled && (
      <script
        is:inline
        set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${analytics.gtmId}');`}
      />
    )}

    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    {gtmEnabled && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${analytics.gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <Header lang={lang} altLangPath={altLangPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
