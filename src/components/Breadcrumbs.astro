---
interface Crumb {
  href?: string;
  label: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-xs mb-4" style="color: var(--color-text-muted);">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {item.href ? (
          <a href={item.href} class="hover:underline" style="color: var(--color-text-muted);">{item.label}</a>
        ) : (
          <span style="color: var(--color-text);">{item.label}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
