---
/**
 * Wiederverwendbare Karte fuer einen Stay22-Live-Hotel-Eintrag.
 * Wird intern von Stay22TopHotels, Stay22NearbyHotels, Saison-Pages benutzt.
 */
import type { Stay22Accommodation } from "../lib/stay22";

interface Props {
  hotel: Stay22Accommodation;
  /** Wenn "total" gezeigt werden soll (Saison-Pages), sonst per-night. */
  showTotal?: boolean;
  /** Distance-Label fuer Nearby-Komponenten. */
  showDistance?: boolean;
}

const { hotel: h, showTotal = false, showDistance = false } = Astro.props;
const priceLabel = showTotal
  ? h.price?.formattedTotal ?? h.price?.formattedPerNight
  : h.price?.formattedPerNight ?? h.price?.formattedTotal;
const priceSuffix = showTotal
  ? (h.price?.formattedTotal ? " gesamt" : "")
  : (h.price?.formattedPerNight ? " / Nacht" : "");
---

<a
  href={h.link || "#"}
  target="_blank"
  rel="sponsored noopener nofollow"
  class="card group block overflow-hidden"
>
  {h.image && (
    <div class="aspect-[4/3] overflow-hidden" style="background: var(--color-surface);">
      <img
        src={h.image}
        alt={h.name}
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer-when-downgrade"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      {h.starRating && (
        <span class="text-xs font-medium" style="color: var(--color-accent);">
          {"★".repeat(Math.round(h.starRating))}
        </span>
      )}
      {h.rating?.score !== undefined && (
        <span class="pill-accent text-[10px]">{h.rating.score.toFixed(1)} / 10</span>
      )}
    </div>
    <h3 class="text-sm font-medium tracking-tight leading-tight mb-2 line-clamp-2 group-hover:text-[var(--color-accent)] transition-colors" style="color: var(--color-text);">
      {h.name}
    </h3>
    {showDistance && h.distance !== undefined && (
      <p class="text-[11px] mb-2" style="color: var(--color-text-muted);">
        {Math.round(h.distance)} m entfernt
      </p>
    )}
    {!showDistance && h.address?.areaName && (
      <p class="text-[11px] mb-2" style="color: var(--color-text-muted);">{h.address.areaName}</p>
    )}
    {priceLabel && (
      <p class="text-sm" style="color: var(--color-text);">
        <span class="font-medium">{priceLabel}</span>
        <span class="text-xs" style="color: var(--color-text-muted);">{priceSuffix}</span>
      </p>
    )}
  </div>
</a>
