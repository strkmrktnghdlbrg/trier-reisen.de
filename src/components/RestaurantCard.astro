---
import HueGradient from "./HueGradient.astro";
import type { Restaurant } from "../data/restaurants";
import { getDistrict } from "../data/districts";
import { detailPath, localize, type Lang } from "../lib/i18n";

interface Props {
  restaurant: Restaurant;
  lang?: Lang;
}

const { restaurant: src, lang = "de" } = Astro.props;
const restaurant = localize("restaurants", src, lang);
const district = localize("districts", getDistrict(restaurant.district) ?? ({ slug: restaurant.district } as any), lang);
---

<a href={detailPath(lang, "restaurants", restaurant.slug)} class="card group block">
  <div class="aspect-[4/3] relative overflow-hidden">
    <HueGradient hue={restaurant.imageHue} label={restaurant.name} class="absolute inset-0" />
    <div class="absolute top-3 left-3">
      <span class="pill bg-white/95 backdrop-blur-sm">{restaurant.cuisine}</span>
    </div>
    <div class="absolute top-3 right-3">
      <span class="pill bg-white/95 backdrop-blur-sm">{restaurant.priceLevel}</span>
    </div>
  </div>
  <div class="p-4">
    <p class="text-xs font-medium mb-1" style="color: var(--color-text-muted);">
      {district?.name ?? restaurant.district}
    </p>
    <h3 class="text-lg font-light tracking-tight leading-tight mb-2 group-hover:text-[var(--color-accent)] transition-colors" style="color: var(--color-text); font-family: var(--font-display);">
      {restaurant.name}
    </h3>
    <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--color-text-body);">
      {restaurant.shortDesc}
    </p>
  </div>
</a>
