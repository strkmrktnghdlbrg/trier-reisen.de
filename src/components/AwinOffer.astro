---
/**
 * AWIN-Angebots-Block fuer Artikel.
 * Rendert CTA-Buttons zu AWIN-Merchants. Solange AWIN nicht scharf ist
 * (publisherId leer / Merchant nicht active), zeigt awinDeeplink den rohen
 * Merchant-Link - der Button funktioniert also immer, trackt nur noch nicht.
 */
import { awinDeeplink, getAwinMerchant } from "../lib/awin";
import type { AwinMerchantKey } from "../data/awin";

interface Props {
  merchants: AwinMerchantKey[];
  heading?: string;
  intro?: string;
  clickref?: string;
  lang?: "de" | "en";
}

const { merchants, intro, clickref, lang = "de" } = Astro.props;
const heading = Astro.props.heading ?? (lang === "en" ? "Matching offers" : "Passende Angebote");
const eyebrowLabel = lang === "en" ? "Ad" : "Anzeige";
const disclaimer =
  lang === "en"
    ? "* Affiliate link. If you book, we may earn a commission at no extra cost to you."
    : "* Affiliate-Link. Bei Buchung erhalten wir ggf. eine Provision, für dich keine Mehrkosten.";

const items = merchants
  .map((key) => {
    const m = getAwinMerchant(key);
    if (!m) return null;
    return { key, name: m.name, href: awinDeeplink(key, { clickref }) };
  })
  .filter((x): x is { key: AwinMerchantKey; name: string; href: string } => x !== null);
---

{items.length > 0 && (
  <section class="my-12 card p-6">
    <p class="eyebrow mb-2">{eyebrowLabel}</p>
    <h2 class="display mb-2">{heading}</h2>
    {intro && <p class="text-body mb-4 max-w-2xl">{intro}</p>}
    <div class="flex flex-wrap gap-3">
      {items.map((it) => (
        <a href={it.href} target="_blank" rel="sponsored nofollow noopener" class="btn-primary">
          {it.name} ↗
        </a>
      ))}
    </div>
    <p class="text-[11px] mt-3" style="color: var(--color-text-muted);">
      {disclaimer}
    </p>
  </section>
)}
