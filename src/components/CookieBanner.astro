---
/**
 * Cookie-Consent-Banner (eigene Loesung, kein externer CMP)
 * ============================================================
 * Steuert das Laden von Drittanbieter-Scripts (Stay22, GetYourGuide,
 * AdSense, GTM) gemaess DSGVO-Einwilligung.
 *
 * Wahl wird in localStorage["trier_consent_v1"] gespeichert:
 *   "all"        -> alle Scripts werden geladen
 *   "essential"  -> kein Drittanbieter-Skript wird geladen
 * Ohne Eintrag bleibt der Banner sichtbar und nichts laedt.
 *
 * Das Inline-Script setzt ausserdem `window.__trierConsent` damit
 * BaseLayout-Loader synchron entscheiden koennen.
 */
import { affiliate, stay22Enabled } from "../data/affiliate";
import { adsense, adsenseEnabled } from "../data/adsense";
import { analytics, gtmEnabled } from "../data/analytics";

const stay22Lma = stay22Enabled ? affiliate.stay22.lmaId : "";
const gygPartner = affiliate.getYourGuide.enabled ? affiliate.getYourGuide.partnerId : "";
const adsensePub = adsenseEnabled ? adsense.publisherId : "";
const gtmId = gtmEnabled ? analytics.gtmId : "";
---

<div
  id="cookie-banner"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookie-banner-title"
  hidden
  class="fixed inset-x-0 bottom-0 z-[60] p-4 sm:p-6"
>
  <div
    class="mx-auto max-w-3xl rounded-2xl border bg-white shadow-2xl p-5 sm:p-6"
    style="border-color: var(--color-border);"
  >
    <h2 id="cookie-banner-title" class="text-lg font-medium mb-1" style="color: var(--color-text);">
      Cookies & Tracking
    </h2>
    <p class="text-sm leading-relaxed" style="color: var(--color-text-body);">
      Wir nutzen Cookies und Drittanbieter-Dienste (Stay22 für Hotelpreise,
      GetYourGuide für Touren, Google Analytics, Google AdSense), um Inhalte zu
      laden, die Nutzung zu analysieren und passende Angebote anzuzeigen.
      Wähle, was du erlauben möchtest. Details in unserer
      <a href="/datenschutz/" class="link-accent">Datenschutzerklärung</a>.
    </p>
    <div class="mt-5 flex flex-col sm:flex-row gap-3">
      <button type="button" data-consent="all" class="btn-primary order-1 sm:order-2">
        Alle akzeptieren
      </button>
      <button type="button" data-consent="essential" class="btn-outline order-2 sm:order-1">
        Nur essentielle
      </button>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{ stay22Lma, gygPartner, adsensePub, gtmId }}
>
  (function () {
    var KEY = "trier_consent_v1";
    var banner = document.getElementById("cookie-banner");

    function loadStay22() {
      if (!stay22Lma || window.__stay22Loaded) return;
      window.__stay22Loaded = true;
      window.Stay22 = window.Stay22 || {};
      window.Stay22.params = { lmaID: stay22Lma };
      var s = document.createElement("script");
      s.async = true;
      s.src = "https://scripts.stay22.com/letmeallez.js";
      document.head.appendChild(s);
    }
    function loadGyg() {
      if (!gygPartner || window.__gygLoaded) return;
      window.__gygLoaded = true;
      var s = document.createElement("script");
      s.async = true;
      s.defer = true;
      s.src = "https://widget.getyourguide.com/dist/pa.umd.production.min.js";
      s.setAttribute("data-gyg-partner-id", gygPartner);
      document.head.appendChild(s);
    }
    function loadAdsense() {
      if (!adsensePub || window.__adsenseLoaded) return;
      window.__adsenseLoaded = true;
      var s = document.createElement("script");
      s.async = true;
      s.src =
        "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=" +
        adsensePub;
      s.crossOrigin = "anonymous";
      document.head.appendChild(s);
    }
    function loadGtm() {
      if (!gtmId || window.__gtmLoaded) return;
      window.__gtmLoaded = true;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
      var s = document.createElement("script");
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtm.js?id=" + gtmId;
      document.head.appendChild(s);
    }

    function applyConsent(value) {
      window.__trierConsent = value;
      if (value === "all") {
        loadStay22();
        loadGyg();
        loadAdsense();
        loadGtm();
      }
    }

    function setConsent(value) {
      try { localStorage.setItem(KEY, value); } catch (e) {}
      applyConsent(value);
      if (banner) banner.hidden = true;
    }

    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (e) {}

    if (stored === "all" || stored === "essential") {
      applyConsent(stored);
    } else if (banner) {
      banner.hidden = false;
    }

    if (banner) {
      banner.querySelectorAll("[data-consent]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          setConsent(btn.getAttribute("data-consent"));
        });
      });
    }

    // Erlaube Footer-Link "Cookie-Einstellungen aendern"
    window.openCookieSettings = function () {
      if (banner) banner.hidden = false;
    };
  })();
</script>
