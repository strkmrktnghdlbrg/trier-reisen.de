---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Stay22HotelCard from "../../components/Stay22HotelCard.astro";
import GygActivities from "../../components/GygActivities.astro";
import { events, type CityEvent, isUpcoming } from "../../data/events";
import { searchAccommodations, type Stay22Accommodation } from "../../lib/stay22";
import { affiliate } from "../../data/affiliate";
import { getGyg, gygCmp } from "../../data/gyg";
import { eventSchema, breadcrumbSchema } from "../../lib/schema";
import { city } from "../../data/city";

export function getStaticPaths() {
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

interface Props { event: CityEvent }
const { event } = Astro.props;

const gygKey = `event:${event.slug}`;
const gyg = getGyg(gygKey);
const upcoming = isUpcoming(event);
const lmaId = affiliate.stay22.lmaId;

let hotels: Stay22Accommodation[] | null = null;
if (upcoming) {
  try {
    hotels = await searchAccommodations({
      provider: "booking",
      ...(event.lat && event.lng
        ? { lat: event.lat, lng: event.lng, radius: event.radius ?? 2500 }
        : { address: event.address }),
      type: "hotel",
      checkin: event.checkin,
      checkout: event.checkout,
      minguestrating: 7.5,
      max: event.maxPricePerNight,
      limit: event.limit ?? 12,
      currency: "EUR",
      lang: "de",
      aid: lmaId,
      campaign: lmaId,
    });
  } catch (err) {
    console.error(`[Event ${event.slug}] Stay22-Fetch:`, err);
  }
}
const visible = hotels && hotels.length > 0 ? hotels.slice(0, event.limit ?? 12) : [];

const checkin = new Date(event.checkin);
const checkout = new Date(event.checkout);
const dateLabel = `${checkin.toLocaleDateString("de-DE", { day: "numeric", month: "long" })} – ${checkout.toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })}`;
const nights = Math.round((checkout.getTime() - checkin.getTime()) / (1000 * 60 * 60 * 24));
const buildTime = new Date().toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" });

if (visible.length > 0) {
  Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400");
}
---

<BaseLayout
  title={event.title}
  description={event.description}
  altLangPath={`/en/events/${event.slug}/`}
  schema={[
    eventSchema(event),
    breadcrumbSchema([
      { name: city.name, url: "/" },
      { name: "Events", url: "/events/" },
      { name: event.title },
    ]),
  ]}
>
  <article class="container-page py-12">
    <Breadcrumbs items={[
      { href: "/", label: city.name },
      { href: "/events/", label: "Events" },
      { label: event.title },
    ]} />

    <div class="max-w-3xl">
      <p class="eyebrow mb-3">{event.eyebrow}</p>
      <h1 class="display-xl mb-4">{event.title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm mb-6">
        <span class="pill">Anreise {checkin.toLocaleDateString("de-DE")}</span>
        <span class="pill">Abreise {checkout.toLocaleDateString("de-DE")}</span>
        <span class="pill">{nights} {nights === 1 ? "Nacht" : "Naechte"}</span>
      </div>
      <p class="text-body text-lg leading-relaxed">{event.intro}</p>
      {event.longDesc && <p class="text-body mt-4 leading-relaxed">{event.longDesc}</p>}
    </div>

    {gyg && (
      <GygActivities q={gyg.q} heading={gyg.heading} intro={gyg.intro} count={gyg.count} cmp={gygCmp(gygKey)} />
    )}

    {!upcoming && (
      <div class="card p-6 max-w-3xl mt-10">
        <p class="text-body">
          Dieses Datum liegt in der Vergangenheit. Sobald der Termin fuer die naechste Saison feststeht, aktualisieren wir die Preise hier.
          Schau dir solange unseren <a href="/hotels/" class="link-accent">Hotel-Index</a> an.
        </p>
      </div>
    )}

    {upcoming && visible.length === 0 && (
      <div class="card p-6 max-w-3xl mt-10">
        <p class="text-body">
          Aktuell zeigt Stay22 keine verfuegbaren Hotels fuer diesen Zeitraum. Probier unseren
          <a href="/hotels/" class="link-accent"> vollstaendigen Hotel-Index</a> oder die
          <a href="/events/" class="link-accent"> anderen Saison-Pages</a>.
        </p>
      </div>
    )}

    {upcoming && visible.length > 0 && (
      <section class="mt-12">
        <div class="mb-6 max-w-2xl">
          <p class="eyebrow mb-2">Live von Stay22 - {dateLabel}</p>
          <h2 class="display mb-2">Hotels fuer diesen Termin</h2>
          <p class="text-body">
            Aktuelle Preise via Booking.com fuer {dateLabel}, {nights} {nights === 1 ? "Nacht" : "Naechte"}.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {visible.map((h) => <Stay22HotelCard hotel={h} showTotal />)}
        </div>

        <p class="text-[11px] mt-6 leading-relaxed max-w-2xl" style="color: var(--color-text-muted);">
          * Preise und Verfuegbarkeit live via Stay22 → Booking.com. Bei Buchung erhalten wir eine Provision - fuer dich keine Mehrkosten.
          Stand: {buildTime}. Preise gelten fuer den Zeitraum {dateLabel}, {nights} {nights === 1 ? "Nacht" : "Naechte"}.
        </p>
      </section>
    )}
  </article>
</BaseLayout>
