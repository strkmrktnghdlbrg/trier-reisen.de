---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import SightCard from "../../components/SightCard.astro";
import RestaurantCard from "../../components/RestaurantCard.astro";
import HueGradient from "../../components/HueGradient.astro";
import ContentImage from "../../components/ContentImage.astro";
import GygActivities from "../../components/GygActivities.astro";
import { categories, type Category } from "../../data/categories";
import { sights } from "../../data/sights";
import { restaurants } from "../../data/restaurants";
import { articles } from "../../data/articles";
import { getGyg, gygCmp } from "../../data/gyg";
import { categorySchema, breadcrumbSchema } from "../../lib/schema";
import { city } from "../../data/city";

export function getStaticPaths() {
  return categories.map((category) => ({ params: { slug: category.slug }, props: { category } }));
}

interface Props { category: Category }
const { category } = Astro.props;
const catSights = sights.filter((s) => s.categories.includes(category.slug));
const catRestaurants = restaurants.filter((r) => r.categories.includes(category.slug));
const catArticles = articles.filter((a) => a.category === category.slug);
const gygKey = `cat:${category.slug}`;
const gyg = getGyg(gygKey);
---

<BaseLayout
  title={`${category.name} in ${city.name}`}
  description={category.shortDesc}
  altLangPath={`/en/themes/${category.slug}/`}
  schema={[
    categorySchema(category),
    breadcrumbSchema([
      { name: city.name, url: "/" },
      { name: "Themen", url: "/kategorien/" },
      { name: category.name },
    ]),
  ]}
>
  <article>
    <div class="container-page py-12">
      <Breadcrumbs items={[
        { href: "/", label: city.name },
        { href: "/kategorien/", label: "Themen" },
        { label: category.name },
      ]} />
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 mt-4 items-center">
        <div class="lg:col-span-3">
          <p class="eyebrow mb-3">Thema · {city.name}</p>
          <h1 class="display-xl mb-4">{category.name}</h1>
          <p class="text-body text-lg leading-relaxed max-w-2xl">{category.longDesc}</p>
        </div>
        <div class="lg:col-span-2 aspect-[16/10] rounded-3xl overflow-hidden relative">
          <ContentImage
            imgKey={`category:${category.slug}`}
            fallbackHue={category.hue}
            fallbackLabel={category.name}
            width={960}
            height={600}
            imgClass="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    {catSights.length > 0 && (
      <section class="container-page section">
        <h2 class="display mb-6">Sehenswürdigkeiten</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {catSights.map((s) => <SightCard sight={s} />)}
        </div>
      </section>
    )}

    {gyg && (
      <div class="container-page">
        <GygActivities q={gyg.q} heading={gyg.heading} intro={gyg.intro} count={gyg.count} cmp={gygCmp(gygKey)} />
      </div>
    )}

    {catRestaurants.length > 0 && (
      <section class="container-page section pt-0">
        <h2 class="display mb-6">Restaurants</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {catRestaurants.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
      </section>
    )}

    {catArticles.length > 0 && (
      <section class="container-page section pt-0">
        <h2 class="display mb-6">Magazin-Artikel</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {catArticles.map((a) => (
            <li>
              <a href={`/${a.slug}/`} class="card group block p-5 h-full">
                <p class="eyebrow mb-2">{category.name}</p>
                <h3 class="text-base font-light leading-snug mb-2 group-hover:text-[var(--color-accent)] transition-colors" style="color: var(--color-text); font-family: var(--font-display);">
                  {a.title}
                </h3>
                <p class="text-sm leading-relaxed line-clamp-3" style="color: var(--color-text-body);">{a.description}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
