---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ContentImage from "../../components/ContentImage.astro";
import SightCard from "../../components/SightCard.astro";
import HotelCard from "../../components/HotelCard.astro";
import RestaurantCard from "../../components/RestaurantCard.astro";
import Stay22NearbyHotels from "../../components/Stay22NearbyHotels.astro";
import Stay22Map from "../../components/Stay22Map.astro";
import GygActivities from "../../components/GygActivities.astro";
import { districts, type District } from "../../data/districts";
import { sights } from "../../data/sights";
import { hotels } from "../../data/hotels";
import { restaurants } from "../../data/restaurants";
import { articles } from "../../data/articles";
import { getGyg, gygCmp } from "../../data/gyg";
import { districtSchema, breadcrumbSchema } from "../../lib/schema";
import { city } from "../../data/city";

export function getStaticPaths() {
  return districts.map((district) => ({ params: { slug: district.slug }, props: { district } }));
}

interface Props { district: District }
const { district } = Astro.props;
const districtSights = sights.filter((s) => s.district === district.slug);
const districtHotels = hotels.filter((h) => h.district === district.slug);
const districtRestaurants = restaurants.filter((r) => r.district === district.slug);
// Related articles: match if intro or any section body paragraph mentions the district slug
const districtArticles = articles.filter((a) => {
  const haystack = [
    a.intro,
    ...a.sections.flatMap((s) => s.body),
  ].join(" ");
  return haystack.includes(district.slug);
}).slice(0, 6);
const gygKey = `district:${district.slug}`;
const gyg = getGyg(gygKey);
---

<BaseLayout
  title={`${district.name} - ${city.name}`}
  description={district.shortDesc}
  altLangPath={`/en/districts/${district.slug}/`}
  schema={[
    districtSchema(district),
    breadcrumbSchema([
      { name: city.name, url: "/" },
      { name: "Bezirke", url: "/bezirke/" },
      { name: district.name },
    ]),
  ]}
>
  <article>
    <div class="container-page py-12">
      <Breadcrumbs items={[
        { href: "/", label: city.name },
        { href: "/bezirke/", label: "Bezirke" },
        { label: district.name },
      ]} />
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 mt-4 items-center">
        <div class="lg:col-span-3">
          <p class="eyebrow mb-3">{city.name} · Bezirk</p>
          <h1 class="display-xl mb-4">{district.name}</h1>
          <p class="text-body text-lg leading-relaxed max-w-2xl">{district.longDesc}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {district.characterTags.map((t) => <span class="pill">{t}</span>)}
          </div>
        </div>
        <div class="lg:col-span-2 aspect-[4/5] rounded-3xl overflow-hidden relative">
          <ContentImage
            imgKey={district.imageKey}
            fallbackHue={district.hue}
            fallbackLabel={district.name}
            imgClass="w-full h-full object-cover"
            width={800}
            height={1000}
          />
        </div>
      </div>
    </div>

    {districtSights.length > 0 && (
      <section class="container-page section">
        <h2 class="display mb-6">Sehenswürdigkeiten in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {districtSights.map((s) => <SightCard sight={s} />)}
        </div>
      </section>
    )}

    {districtHotels.length > 0 && (
      <section class="container-page section pt-0">
        <h2 class="display mb-6">Hotels in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {districtHotels.map((h) => <HotelCard hotel={h} />)}
        </div>
      </section>
    )}

    <div class="container-page">
      {gyg && (
        <GygActivities q={gyg.q} heading={gyg.heading} intro={gyg.intro} count={gyg.count} cmp={gygCmp(gygKey)} />
      )}

      <Stay22NearbyHotels
        lat={district.coordinates[0]}
        lng={district.coordinates[1]}
        near={district.name}
        radius={2000}
        limit={4}
      />

      <Stay22Map
        lat={district.coordinates[0]}
        lng={district.coordinates[1]}
        zoom={14}
        title={`Hotels in ${district.name} - Live-Karte`}
        lead="Aktuelle Preise via Booking. Zoom rein, Marker antippen, buchen."
      />
    </div>

    {districtRestaurants.length > 0 && (
      <section class="container-page section pt-0">
        <h2 class="display mb-6">Restaurants in {district.name}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {districtRestaurants.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
      </section>
    )}

    {districtArticles.length >= 2 && (
      <section class="container-page section pt-0">
        <h2 class="display mb-6">Magazin-Tipps zu {district.name}</h2>
        <ul class="flex flex-col gap-3">
          {districtArticles.map((a) => (
            <li>
              <a href={`/${a.slug}/`} class="link-accent text-base">{a.title} &rarr;</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
