---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ContentImage from "../../components/ContentImage.astro";
import SightCard from "../../components/SightCard.astro";
import Stay22NearbyHotels from "../../components/Stay22NearbyHotels.astro";
import GygActivities from "../../components/GygActivities.astro";
import { sights, type Sight } from "../../data/sights";
import { getDistrict } from "../../data/districts";
import { getCategory } from "../../data/categories";
import { getGyg, gygCmp } from "../../data/gyg";
import sightEnrichments from "../../data/sight-enrichments.json";
import { sightSchema, breadcrumbSchema } from "../../lib/schema";
import { city } from "../../data/city";

export function getStaticPaths() {
  return sights.map((sight) => ({ params: { slug: sight.slug }, props: { sight } }));
}

interface Props { sight: Sight }
const { sight } = Astro.props;
const district = getDistrict(sight.district);
const related = sights.filter((s) => s.slug !== sight.slug && s.district === sight.district).slice(0, 3);
const cats = sight.categories.map((c) => getCategory(c)).filter(Boolean);
const priceLabel = sight.priceFrom === null ? "Eintritt frei" : `ab ${sight.priceFrom} €`;
const gygKey = `sight:${sight.slug}`;
const gyg = getGyg(gygKey);
const moreInfo: string[] = (sightEnrichments as Record<string, string[]>)[sight.slug] ?? [];
---

<BaseLayout
  title={sight.name}
  description={sight.shortDesc}
  altLangPath={`/en/sights/${sight.slug}/`}
  schema={[
    sightSchema(sight),
    breadcrumbSchema([
      { name: city.name, url: "/" },
      { name: "Sehenswürdigkeiten", url: "/sehenswuerdigkeiten/" },
      { name: sight.name },
    ]),
  ]}
>
  <article class="container-page py-12">
    <Breadcrumbs items={[
      { href: "/", label: city.name },
      { href: "/sehenswuerdigkeiten/", label: "Sehenswürdigkeiten" },
      { label: sight.name },
    ]} />

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 mt-4">
      <div class="lg:col-span-3">
        <p class="eyebrow mb-3">{sight.type}{sight.unesco ? " · UNESCO-Welterbe" : ""}</p>
        <h1 class="display-xl mb-4">{sight.name}</h1>
        <p class="text-sm" style="color: var(--color-text-muted);">
          {district?.name ?? sight.district} · {priceLabel}
          {sight.openingHours && <> · {sight.openingHours}</>}
        </p>
        <div class="aspect-[16/10] rounded-2xl overflow-hidden mt-6 relative">
          <ContentImage
            imgKey={sight.imageKey}
            fallbackHue={sight.imageHue}
            fallbackLabel={sight.name}
            imgClass="w-full h-full object-cover"
            width={1200}
            height={750}
          />
        </div>
        <p class="text-body mt-8 text-lg leading-relaxed">{sight.longDesc}</p>

        {moreInfo.map((para) => (
          <p class="text-body mt-4 leading-relaxed">{para}</p>
        ))}

        {cats.length > 0 && (
          <div class="mt-8">
            <p class="eyebrow mb-3">Themen</p>
            <div class="flex flex-wrap gap-2">
              {cats.map((c) => c && <a href={`/kategorien/${c.slug}/`} class="pill hover:border-[var(--color-accent)] transition-colors">{c.name}</a>)}
            </div>
          </div>
        )}
      </div>

      <aside class="lg:col-span-2">
        <div class="card p-6">
          <h2 class="text-lg font-light mb-4" style="font-family: var(--font-display);">Praktisches</h2>
          <dl class="text-sm space-y-3">
            <div>
              <dt style="color: var(--color-text-muted);">Bezirk</dt>
              <dd style="color: var(--color-text);">{district?.name ?? sight.district}</dd>
            </div>
            <div>
              <dt style="color: var(--color-text-muted);">Eintritt</dt>
              <dd style="color: var(--color-text);">{priceLabel}</dd>
            </div>
            {sight.openingHours && (
              <div>
                <dt style="color: var(--color-text-muted);">Öffnungszeiten</dt>
                <dd style="color: var(--color-text);">{sight.openingHours}</dd>
              </div>
            )}
            {sight.websiteUrl && (
              <div>
                <dt style="color: var(--color-text-muted);">Website</dt>
                <dd><a href={sight.websiteUrl} target="_blank" rel="noopener" class="link-accent text-sm">Offizielle Seite ↗</a></dd>
              </div>
            )}
            <div>
              <dt style="color: var(--color-text-muted);">Koordinaten</dt>
              <dd style="color: var(--color-text);" class="font-mono text-xs">{sight.coordinates[0].toFixed(4)}, {sight.coordinates[1].toFixed(4)}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>

    {gyg && (
      <GygActivities
        q={gyg.q}
        heading={gyg.heading}
        intro={gyg.intro}
        count={gyg.count}
        cmp={gygCmp(gygKey)}
      />
    )}

    <Stay22NearbyHotels
      lat={sight.coordinates[0]}
      lng={sight.coordinates[1]}
      near={sight.name}
      radius={1500}
      limit={4}
    />

    {related.length > 0 && (
      <section class="section">
        <h2 class="display mb-6">Weiter in {district?.name ?? sight.district}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {related.map((s) => <SightCard sight={s} />)}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
