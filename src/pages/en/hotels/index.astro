---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import HotelCard from "../../../components/HotelCard.astro";
import Stay22TopHotels from "../../../components/Stay22TopHotels.astro";
import { city } from "../../../data/city";
import { hotels } from "../../../data/hotels";
import { localize, t } from "../../../lib/i18n";
import { breadcrumbSchema } from "../../../lib/schema";

const lang = "en" as const;
const localized = hotels.map((h) => localize("hotels", h, lang));
---

<BaseLayout
  title={`Hotels in ${city.name}`}
  description={`Hotels in ${city.name}: ${hotels.length} curated properties across all districts, with live prices.`}
  lang={lang}
  altLangPath="/hotels/"
  schema={breadcrumbSchema([{ name: city.name, url: "/en/" }, { name: t(lang, "breadcrumb.hotels") }])}
>
  <section class="container-page py-12">
    <Breadcrumbs items={[{ href: "/en/", label: city.name }, { label: t(lang, "breadcrumb.hotels") }]} />
    <h1 class="display-xl">{t(lang, "nav.hotels")} in {city.name}</h1>
    <p class="text-body mt-4 max-w-2xl">
      Curated hotels across the city, from boutique town houses to wellness resorts. Live prices via Booking.com.
    </p>
  </section>

  <section class="container-page section pt-0">
    <Stay22TopHotels limit={8} lang="en" />
  </section>

  <section class="container-page section pt-0">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {localized.map((h) => <HotelCard hotel={h} lang={lang} />)}
    </div>
  </section>
</BaseLayout>
