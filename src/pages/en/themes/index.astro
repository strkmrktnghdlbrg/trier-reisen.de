---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CategoryCard from "../../../components/CategoryCard.astro";
import GygActivities from "../../../components/GygActivities.astro";
import { city } from "../../../data/city";
import { categories } from "../../../data/categories";
import { getGyg, gygCmp } from "../../../data/gyg";
import { localize, t } from "../../../lib/i18n";
import { breadcrumbSchema } from "../../../lib/schema";

const lang = "en" as const;
const localized = categories.map((c) => localize("categories", c, lang));
const gyg = getGyg("index:kategorien");
---

<BaseLayout
  title={`Themes - ${city.name}`}
  description={`${categories.length} themes: UNESCO heritage, Roman heritage, wine, Mosel activities, families, museums, views and hiking.`}
  lang={lang}
  altLangPath="/kategorien/"
  schema={breadcrumbSchema([{ name: city.name, url: "/en/" }, { name: t(lang, "breadcrumb.themes") }])}
>
  <section class="container-page py-12">
    <Breadcrumbs items={[{ href: "/en/", label: city.name }, { label: t(lang, "breadcrumb.themes") }]} />
    <h1 class="display-xl">Trier by interest</h1>
    <p class="text-body mt-4 max-w-2xl">Not every Trier trip starts at the Hauptmarkt. Wine travellers start in Olewig, families at the Toy Museum, architecture fans at the Basilica of Constantine.</p>
  </section>

  <section class="container-page section pt-0">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {localized.map((c) => <CategoryCard category={c} lang={lang} />)}
    </div>
  </section>

  {gyg && (
    <div class="container-page">
      <GygActivities q={gyg.q} heading={gyg.heading} intro={gyg.intro} count={gyg.count} cmp={gygCmp("index:kategorien")} />
    </div>
  )}
</BaseLayout>
