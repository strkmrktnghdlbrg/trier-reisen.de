---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { city } from "../data/city";

const stadt = city.name; // "Trier"

type Bezug = "lebt aktuell" | "geboren" | "aufgewachsen" | "hat lange gelebt" | "eng verbunden";
interface Person {
  name: string;
  kategorie: string;
  bezug: Bezug;
  fakt: string;
}

const personen: Person[] = [
  { name: "Karl Marx", kategorie: "Wissenschaft", bezug: "geboren", fakt: "Der Philosoph und Begründer des wissenschaftlichen Sozialismus wurde 1818 in Trier geboren, sein Geburtshaus in der Brückenstraße ist heute ein Museum." },
  { name: "Ambrosius von Mailand", kategorie: "Wissenschaft", bezug: "geboren", fakt: "Der um 339 in Trier geborene Kirchenvater zählt zu den bedeutendsten Theologen der Spätantike." },
  { name: "Guildo Horn", kategorie: "Musik", bezug: "geboren", fakt: "Der 1963 in Trier geborene Schlagersänger vertrat Deutschland 1998 mit Guildo hat euch lieb beim Eurovision Song Contest." },
  { name: "Christian Jost", kategorie: "Musik", bezug: "geboren", fakt: "Der 1963 in Trier geborene Komponist und Dirigent zählt zu den bekannten zeitgenössischen Opernkomponisten." },
  { name: "Gitta Lind", kategorie: "Musik", bezug: "geboren", fakt: "Die 1925 in Trier geborene Schlagersängerin gehörte in den 1950er Jahren zu den erfolgreichen Interpretinnen ihrer Zeit." },
  { name: "Ernst Huberty", kategorie: "Film/TV", bezug: "geboren", fakt: "Der 1927 in Trier geborene Sportreporter wurde als Mister Sportschau zu einer Legende des deutschen Fernsehens." },
  { name: "Clara Viebig", kategorie: "Kunst", bezug: "geboren", fakt: "Die 1860 in Trier geborene Schriftstellerin wurde mit ihren Romanen über die Eifel bekannt." },
  { name: "Eric Jelen", kategorie: "Sport", bezug: "geboren", fakt: "Der 1965 in Trier geborene Tennisspieler gewann mit dem deutschen Team die Davis-Cup-Titel 1988 und 1989." },
];

const faq = [
  { frage: "Welcher berühmte Philosoph wurde in Trier geboren?", antwort: "Karl Marx, der Begründer des wissenschaftlichen Sozialismus, wurde 1818 in Trier geboren. Sein Geburtshaus in der Brückenstraße ist heute ein Museum." },
  { frage: "Welche Promis kommen aus Trier?", antwort: "Neben Karl Marx stammen der Schlagersänger Guildo Horn, der Sportreporter Ernst Huberty und der Tennisprofi Eric Jelen aus Trier." },
  { frage: "Ist Guildo Horn in Trier geboren?", antwort: "Ja, der Schlagersänger Guildo Horn wurde 1963 in Trier geboren und trat 1998 beim Eurovision Song Contest an." },
  { frage: "Welche Sportler oder Sportreporter stammen aus Trier?", antwort: "Aus Trier stammen der Tennisprofi und Davis-Cup-Sieger Eric Jelen sowie der als Mister Sportschau bekannte Sportreporter Ernst Huberty." },
];

// Reihenfolge der Kategorien
const kategorien = [...new Set(personen.map((p) => p.kategorie))];

const bezugLabel: Record<Bezug, string> = {
  "lebt aktuell": `lebt in ${stadt}`,
  geboren: `geboren in ${stadt}`,
  aufgewachsen: `aufgewachsen in ${stadt}`,
  "hat lange gelebt": `lange in ${stadt} gelebt`,
  "eng verbunden": `eng mit ${stadt} verbunden`,
};

const h1 = `Welche Promis leben in ${stadt}?`;
const seoTitle = `Welche Promis leben in ${stadt}? Bekannte Persönlichkeiten`;
const description = "Welche Promis kommen aus Trier? Trier ist die Geburtsstadt von Karl Marx. Dazu Guildo Horn, Ernst Huberty und weitere bekannte Trierer aus Musik, Sport und Kultur.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: h1,
      description,
      inLanguage: "de-DE",
      about: { "@type": "Place", name: stadt },
      mainEntityOfPage: new URL(Astro.url.pathname, city.domain).toString(),
    },
    {
      "@type": "ItemList",
      name: `Bekannte Persönlichkeiten aus ${stadt}`,
      itemListElement: personen.map((p, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: { "@type": "Person", name: p.name, description: p.fakt },
      })),
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.frage,
        acceptedAnswer: { "@type": "Answer", text: f.antwort },
      })),
    },
  ],
};
---

<BaseLayout title={seoTitle} description={description} schema={jsonLd}>
  <section class="container-page py-10">
    <Breadcrumbs items={[{ label: stadt, href: "/" }, { label: `Promis in ${stadt}` }]} />

    <div class="max-w-3xl">
      <p class="eyebrow mb-3">Bekannte Persönlichkeiten</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-6 text-balance" style="color: var(--color-text);">
        {h1}
      </h1>
      <p class="text-lg leading-relaxed mb-6" style="color: var(--color-text-body);">
        Trier, die älteste Stadt Deutschlands, ist vor allem als Geburtsstadt von Karl Marx weltbekannt. Doch die Moselmetropole hat weit mehr prominente Namen hervorgebracht, von Schlagerstars über Sportreporter bis zu Tennisprofis. Diese Übersicht zeigt bekannte Persönlichkeiten mit ihrem Bezug zu {stadt}.
      </p>
      <p class="text-sm leading-relaxed mb-10" style="color: var(--color-text-muted);">
        Hinweis: Die folgende Übersicht umfasst Persönlichkeiten, die in {stadt} geboren oder aufgewachsen sind, lange hier gelebt haben oder eng mit der Stadt verbunden sind. Jeder Eintrag ist entsprechend gekennzeichnet.
      </p>
    </div>

    {kategorien.map((kat) => (
      <div class="max-w-3xl mb-10">
        <h2 class="text-2xl font-bold mb-5" style="color: var(--color-text);">{kat}</h2>
        <ul class="space-y-4">
          {personen.filter((p) => p.kategorie === kat).map((p) => (
            <li class="card p-5">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-2">
                <span class="text-lg font-bold" style="color: var(--color-text);">{p.name}</span>
                <span class="text-xs font-semibold px-2.5 py-1" style="background: var(--color-accent-tint); color: var(--color-accent); border-radius: var(--radius-badge);">
                  {bezugLabel[p.bezug]}
                </span>
              </div>
              <p class="leading-relaxed" style="color: var(--color-text-body);">{p.fakt}</p>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="max-w-3xl mt-14">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text);">Häufige Fragen zu Promis aus {stadt}</h2>
      <div class="space-y-4">
        {faq.map((f) => (
          <details class="card p-5">
            <summary class="font-semibold cursor-pointer" style="color: var(--color-text);">{f.frage}</summary>
            <p class="mt-3 leading-relaxed" style="color: var(--color-text-body);">{f.antwort}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="max-w-3xl mt-14 pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-text);">Mehr über {stadt}</h2>
      <ul class="flex flex-wrap gap-3">
        <li><a href="/sehenswuerdigkeiten/" class="underline" style="color: var(--color-accent); text-underline-offset: 3px;">Sehenswürdigkeiten in {stadt}</a></li>
        <li><a href="/" class="underline" style="color: var(--color-accent); text-underline-offset: 3px;">Startseite {city.brandName}</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
