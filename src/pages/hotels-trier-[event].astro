---
/**
 * Saison-/Event-Landing-Pages fuer Stay22-Hotels.
 * Schema:  /hotels-trier-<slug>/
 *   /hotels-trier-antikenfestspiele-2026/
 *   /hotels-trier-weihnachtsmarkt-2026/
 *   /hotels-trier-silvester-2026/
 *   /hotels-trier-pfingsten-2026/
 *   /hotels-trier-wochenende/
 *   ...
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Stay22HotelCard from "../components/Stay22HotelCard.astro";
import Stay22Map from "../components/Stay22Map.astro";
import { events, isUpcoming, type CityEvent } from "../data/events";
import { searchAccommodations, type Stay22Accommodation } from "../lib/stay22";
import { affiliate } from "../data/affiliate";
import { city } from "../data/city";

export function getStaticPaths() {
  return events.map((e) => ({ params: { event: e.slug }, props: { event: e } }));
}

interface Props { event: CityEvent }
const { event } = Astro.props;

const upcoming = isUpcoming(event);
const lmaId = affiliate.stay22.lmaId;

let hotels: Stay22Accommodation[] | null = null;
if (upcoming) {
  try {
    hotels = await searchAccommodations({
      provider: "booking",
      ...(event.lat && event.lng
        ? { lat: event.lat, lng: event.lng, radius: event.radius ?? 2500 }
        : { address: event.address }),
      type: "hotel",
      checkin: event.checkin,
      checkout: event.checkout,
      minguestrating: 7.5,
      max: event.maxPricePerNight,
      limit: event.limit ?? 12,
      currency: "EUR",
      lang: "de",
      aid: lmaId,
      campaign: lmaId,
    });
  } catch (err) {
    console.error(`[hotels-trier-${event.slug}] Stay22-Fetch:`, err);
  }
}
const visible = hotels && hotels.length > 0 ? hotels.slice(0, event.limit ?? 12) : [];

const checkin = new Date(event.checkin);
const checkout = new Date(event.checkout);
const checkinFmt = checkin.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" });
const checkoutFmt = checkout.toLocaleDateString("de-DE", { day: "2-digit", month: "long", year: "numeric" });
const nights = Math.round((checkout.getTime() - checkin.getTime()) / (1000 * 60 * 60 * 24));
const buildTime = new Date().toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" });

const title = event.kind === "season" ? event.title : `Hotels in Trier zu ${event.eyebrow}`;

if (visible.length > 0) {
  Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400");
}
---

<BaseLayout title={title} description={event.description}>
  <article class="container-page py-12">
    <Breadcrumbs items={[
      { href: "/", label: city.name },
      { href: "/hotels/", label: "Hotels" },
      { label: event.eyebrow },
    ]} />

    <div class="max-w-3xl mb-8">
      <p class="eyebrow mb-3">{event.eyebrow}</p>
      <h1 class="display-xl mb-4">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm mb-6">
        <span class="pill">Anreise {checkinFmt}</span>
        <span class="pill">Abreise {checkoutFmt}</span>
        <span class="pill">{nights} {nights === 1 ? "Nacht" : "Naechte"}</span>
      </div>
      <p class="text-body text-lg leading-relaxed">{event.intro}</p>
      {event.longDesc && <p class="text-body mt-4 leading-relaxed">{event.longDesc}</p>}
    </div>

    {!upcoming && (
      <div class="card p-6 max-w-3xl">
        <p class="text-body">
          Dieses Datum liegt in der Vergangenheit. Schau dir solange unseren
          <a href="/hotels/" class="link-accent"> Hotel-Index</a> an.
        </p>
      </div>
    )}

    {upcoming && visible.length > 0 && (
      <>
        <section>
          <div class="mb-6 max-w-2xl">
            <p class="eyebrow mb-2">Live von Stay22</p>
            <h2 class="display mb-2">Verfuegbare Hotels - {checkinFmt} bis {checkoutFmt}</h2>
            <p class="text-body">Echte Preise via Booking.com fuer diesen Zeitraum.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {visible.map((h) => <Stay22HotelCard hotel={h} showTotal />)}
          </div>
          <p class="text-[11px] mt-6 leading-relaxed max-w-2xl" style="color: var(--color-text-muted);">
            * Live via Stay22 → Booking.com. Stand: {buildTime}. Provision bei Buchung - kein Mehrpreis fuer dich.
          </p>
        </section>

        {event.lat && event.lng && (
          <Stay22Map
            lat={event.lat}
            lng={event.lng}
            zoom={14}
            title="Hotel-Karte"
            lead={`Alle Hotels rund um ${event.address} mit Live-Preisen.`}
          />
        )}
      </>
    )}

    {upcoming && visible.length === 0 && (
      <div class="card p-6 max-w-3xl">
        <p class="text-body">
          Aktuell zeigt Stay22 keine verfuegbaren Hotels fuer diesen Zeitraum.
          Probier unseren <a href="/hotels/" class="link-accent">vollstaendigen Hotel-Index</a>.
        </p>
      </div>
    )}
  </article>
</BaseLayout>
