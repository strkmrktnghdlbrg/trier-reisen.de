# WWW-CANONICAL-BEGIN (auto) - www -> Apex (kanonisch, 301)
<IfModule mod_rewrite.c>
  RewriteEngine On

# ============================================================
# Bot-Block auf den Affiliate-Redirects (/r/)
# Bots folgen die 302 auf awin1.com; AWIN zaehlt JEDEN Hit als Klick.
# Messung 01.-23.07.2026: bis 66 % Klicks je GA4-Session, 5 Sales auf 2.052 Klicks.
# Greift NUR auf /r/ und /go/ (Outbound-Gate) - der Content bleibt fuer alle Crawler erreichbar,
# ein False-Positive kostet also hoechstens einen Partnerlink, nie Indexierung.
# ============================================================
RewriteCond %{HTTP_USER_AGENT} (crawl|spider|slurp|scraper|archiver|indexer) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (curl/|wget|python-|go-http|java/|okhttp|libwww|scrapy|axios|node-fetch|guzzle|httpclient) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (headlesschrome|phantomjs|puppeteer|playwright|selenium) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (zgrab|masscan|nmap|nikto|sqlmap|wpscan|censys|nuclei|acunetix|netsparker|qualys) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (googlebot|bingbot|yandexbot|duckduckbot|applebot|seznambot|exabot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (ahrefsbot|semrushbot|mj12bot|dotbot|blexbot|petalbot|seokicks|sistrix|serpstatbot|dataforseo|majestic|sitebulb|seobility|netcraft|screaming) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|oai-searchbot|ccbot|claudebot|claude-web|anthropic|perplexity|amazonbot|bytespider|meta-externalagent|google-extended|diffbot|omgili|timpibot|youbot|imagesift|cohere) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|pinterest|redditbot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} ^$
RewriteRule ^(r|go)/ - [F,L]

# ---- Affiliate-Redirects (/r/...) 302, clickref = trier-reisen.de (AWIN 514869) ----
RewriteRule ^r/docmorris(-10euro)?/?$ https://www.awin1.com/cread.php?s=2490784&v=14485&q=372737&r=514869&clickref=trier-reisen.de [R=302,L,NE]
RewriteRule ^r/shop-apotheke(-rezept)?/?$ https://www.awin1.com/cread.php?s=3450028&v=13808&q=471107&r=514869&clickref=trier-reisen.de [R=302,L,NE]
RewriteRule ^r/mediherz(-gutscheine)?/?$ https://www.awin1.com/cread.php?s=2269210&v=11630&q=348918&r=514869&clickref=trier-reisen.de [R=302,L,NE]
RewriteRule ^r/medpex(-zuzahlungsfrei)?/?$ https://www.awin1.com/awclick.php?gid=447437&mid=36320&awinaffid=514869&linkid=3237938&clickref=trier-reisen.de [R=302,L,NE]
RewriteRule ^r/fliegende-pillen/?$ https://t.adcell.com/p/click?promoId=120221&slotId=78194&subId=trier-reisen.de&param0=https://www.fliegende-pillen.de/ [R=302,L,NE]
RewriteRule ^r/parken-fliegen/?$ https://www.awin1.com/cread.php?awinmid=14793&awinaffid=514869&clickref=trier-reisen.de [R=302,L,NE]

# ---- 301-Redirects Alt-WP-Artikel -> Sehenswuerdigkeiten-Seiten ----
# Quelle: public/_redirects (CF-Pages-Syntax, von LiteSpeed ignoriert)
RewriteRule ^porta-nigra/?$ https://trier-reisen.de/sehenswuerdigkeiten/porta-nigra/ [R=301,L]
RewriteRule ^kaiserthermen(/.*)?$ https://trier-reisen.de/sehenswuerdigkeiten/kaiserthermen/ [R=301,L]
RewriteRule ^trierer-dom/?$ https://trier-reisen.de/sehenswuerdigkeiten/trierer-dom/ [R=301,L]
RewriteRule ^amphitheater-trier/?$ https://trier-reisen.de/sehenswuerdigkeiten/amphitheater/ [R=301,L]
RewriteRule ^barbarathermen/?$ https://trier-reisen.de/sehenswuerdigkeiten/barbarathermen/ [R=301,L]
RewriteRule ^liebfrauenkirche-gotisch/?$ https://trier-reisen.de/sehenswuerdigkeiten/liebfrauenkirche/ [R=301,L]
RewriteRule ^palastgarten/?$ https://trier-reisen.de/sehenswuerdigkeiten/kurfuerstliches-palais/ [R=301,L]
RewriteRule ^marktkreuz/?$ https://trier-reisen.de/sehenswuerdigkeiten/hauptmarkt/ [R=301,L]
RewriteRule ^petrusbrunnen/?$ https://trier-reisen.de/sehenswuerdigkeiten/hauptmarkt/ [R=301,L]
RewriteRule ^thermen-am-viehmarkt/?$ https://trier-reisen.de/viehmarktthermen/ [R=301,L]

  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L,NE]
</IfModule>
# WWW-CANONICAL-END

